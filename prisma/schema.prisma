generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("RETAILER")
  storeName String?

  // Active try-on provider for this retailer's store ("gemini" | "vertex").
  // Defaults to Gemini — matches prior hardcoded behavior. Resolved at
  // request time with a graceful fallback to Gemini if the choice is disabled.
  tryOnProvider String @default("gemini")

  // AI Generation (model-image) preferences as JSON, e.g.
  // { "defaultModelType": "woman", "defaultObjective": "catalogue",
  //   "brandingEnabled": true, "brandingPosition": "top-right" }.
  // Nullable → existing rows are unaffected. A single column keeps the growing
  // settings surface migration-free (see docs/IMAGE_AI_ROADMAP.md §8). Read via
  // the typed accessor in lib/model-gen/settings.ts — never parsed inline.
  aiGenSettings String?

  // Cloudinary public_id of the store logo, overlaid on generated model images
  // when present (else the store name is used). Nullable → no logo by default.
  logoPublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]

  @@map("users")
}

model Product {
  id          String  @id @default(cuid())
  title       String
  description String?
  category    String
  subcategory String?

  color  String
  colors String @default("[]")

  occasion  String @default("[]")
  styleTags String @default("[]")
  material  String?
  gender    String @default("WOMEN")
  season    String @default("[]")
  price     Float

  imageUrl      String?
  thumbnailUrl  String?
  modelImageUrl String?

  inStock  Boolean @default(true)
  isActive Boolean @default(true)

  sku String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendationsFrom Recommendation[] @relation("SourceProduct")
  recommendationsTo   Recommendation[] @relation("TargetProduct")

  generatedImages ProductImage[]

  @@index([category])
  @@index([userId])
  @@index([color])
  @@map("products")
}

// AI-generated catalogue/model images for a product. Additive: the single
// Product.modelImageUrl column stays as the legacy/primary output (Quick Listing
// writes it); this table holds the multi-view catalogue gallery (front, back,
// pallu, border, ...). One row per generated view so individual images can be
// regenerated, deleted, or shared independently.
model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  // The catalogue view this image represents: "front" | "back" | "pallu" |
  // "border" | "blouse" | "fabric" | ... (see lib/model-gen/prompt-sets.ts).
  view      String
  // The generation objective that produced it: "quick_listing" | "catalogue".
  objective String
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model Recommendation {
  id              String @id @default(cuid())
  sourceProductId String
  targetProductId String

  matchScore    Float
  categoryScore Float
  colorScore    Float
  occasionScore Float
  styleScore    Float
  confidence    Float

  explanation     String
  explanationTags String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceProduct Product @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("TargetProduct", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId])
  @@index([sourceProductId, matchScore])
  @@map("recommendations")
}
