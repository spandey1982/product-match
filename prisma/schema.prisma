generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String  @id @default(cuid())
  email     String  @unique
  name      String
  password  String
  role      String  @default("RETAILER")
  storeName String?

  tryOnProvider String  @default("gemini")
  aiGenSettings String?
  logoPublicId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      Product[]
  modelProfiles ModelProfile[]

  @@map("users")
}

/**
 * End-customer identity for the /rent marketplace — deliberately separate
 * from User (the retailer/tenant entity). Authenticated via mobile OTP, not
 * email/password, and carries none of the retailer-only fields on User.
 */
model Customer {
  id    String  @id @default(cuid())
  phone String  @unique
  name  String?
  email String?

  addresses    CustomerAddress[]
  rentalOrders RentalOrder[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("customers")
}

model CustomerAddress {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  label     String?
  line1     String
  pincode   String
  landmark  String?
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@map("customer_addresses")
}

// Mocked rental request/order — no payment integration behind this yet.
// productId is deliberately NOT a relation to Product: this is a durable
// snapshot (title/image/store captured at request time) that must survive
// the product being edited or deleted later, same rationale as
// GenerationRecord above.
model RentalOrder {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  productId    String
  productTitle String
  productImage String?
  storeName    String?

  ageGroup           String
  rentalPricePerDay  Float
  deposit            Float
  rentalDurationDays Int

  customerName  String
  customerPhone String
  customerEmail String?

  addressLine1    String
  addressPincode  String
  addressLandmark String?

  eventDate           String
  deliverySlot        String
  specialInstructions String?

  deliveryDate        String
  expectedTrialWindow String

  paymentMethod String @default("Pay at Doorstep")
  // "requested" | "confirmed" | "preparing" | "out_for_delivery" | "trial" |
  // "delivered" | "pickup_scheduled" | "completed" | "cancelled" — plain
  // string per this schema's stage-field convention (see AutoCatalogItem),
  // not a Prisma enum.
  status        String @default("requested")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([productId])
  @@map("rental_orders")
}

model Product {
  id          String  @id @default(cuid())
  title       String
  description String?
  category    String
  subcategory String?

  color  String
  colors String @default("[]")

  occasion        String  @default("[]")
  styleTags       String  @default("[]")
  material        String?
  // Visual pattern/print (e.g. Floral, Paisley, Zari, Solid). Extracted by the
  // shared metadata service (lib/metadata) and reused by generation + future
  // recommendation/stylist systems. Nullable → existing rows unaffected.
  pattern         String?
  // Concise generation hints — the visually critical specifics the model must
  // preserve (weave/technique, motifs, border, embellishment, texture).
  // Lazily extracted once (category-aware) and cached; fed into the generation
  // prompt so fine detail isn't lost during synthesis. Nullable → safe default.
  detailNotes     String?
  // Same, but for the back image — fed only into the BACK-view prompt (catalogue
  // generates a back view; quick-listing is front-only so never uses this).
  backDetailNotes String?
  gender          String  @default("WOMEN")
  season          String  @default("[]")
  price           Float

  imageUrl      String?
  // Optional back-of-product image. When present, back-profile catalogue
  // generation uses it instead of the model inventing the back. Nullable →
  // existing products and the current flow are unaffected.
  backImageUrl  String?
  // Optional category-specific detail close-ups (pallu/border/blouse/skirt/…),
  // as a JSON array of { slot, label, url }. EXTRACTION-ONLY — fed to the
  // metadata/detail extractor to enrich the prompt, never sent to the image
  // generator (so generation token cost is unchanged). Nullable → safe default.
  partImages    String?
  thumbnailUrl  String?
  modelImageUrl String?

  inStock  Boolean @default(true)
  isActive Boolean @default(true)

  sku String? @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recommendationsFrom Recommendation[] @relation("SourceProduct")
  recommendationsTo   Recommendation[] @relation("TargetProduct")

  generatedImages ProductImage[]

  // Structured garment intelligence (R&D) — one deep vision analysis per
  // product, reused everywhere. Nullable → existing rows unaffected.
  garmentIntelligence GarmentIntelligence?

  @@index([category])
  @@index([userId])
  @@index([color])
  @@map("products")
}

// Structured Garment Intelligence (R&D — docs/research/GARMENT_INTELLIGENCE_RND.md).
//
// One row per product: the persisted result of the hierarchical vision
// analysis ("what makes this garment unique?" — construction, surface
// techniques, pattern, texture, craftsmanship). Deliberately separate from
// metadata extraction ("what is this product?"). Extracted once, then reused
// by every consumer (generation prompts today; descriptions/search/
// recommendations later) — the cost-philosophy contract.
model GarmentIntelligence {
  id        String  @id @default(cuid())
  productId String  @unique
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  // Full structured intelligence as a JSON string (lib/garment-intelligence/
  // types.ts is the source of truth for its shape; parse with the service,
  // never by hand).
  data String

  // Deterministically rendered prompt fragment (cached so generation never
  // re-renders, and so the exact text fed to the generator is auditable).
  promptNotes String

  // Rendered BACK-view prompt fragment, when a back image was analyzed.
  // Null → no back image existed (the back-view prompt falls back to the
  // deterministic "plain or continues the body pattern" guard clause).
  backPromptNotes String?

  // The product image URL this analysis was computed from — when the product's
  // image changes, the mismatch invalidates the cache and triggers re-analysis.
  analyzedImageUrl String

  // Same for the back image (null when none existed at analysis time).
  analyzedBackImageUrl String?

  // Vision model that produced the analysis (provider benchmarking later).
  model String

  // Schema version of `data` — bump when the structured shape changes so old
  // rows can be migrated or lazily re-analyzed.
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("garment_intelligence")
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  view      String
  objective String
  isPrimary Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

// Performance + quality record for one generated image. Deliberately NOT a
// foreign-key child of Product: these are durable analytics snapshots that must
// survive product edits/deletes, so category/provider/objective are copied in.
// AI scores (Phase F) and manual scores (Phase G) are filled in later; null
// until reviewed.
model GenerationRecord {
  id        String  @id @default(cuid())
  productId String?
  userId    String?

  provider  String // "gemini" | "vertex"
  modelName String? // e.g. "gemini-3.1-flash-image", "virtual-try-on-001"
  category  String
  objective String // "quick_listing" | "catalogue"
  view      String // "front" | "back" | "front-top" | ...
  outputUrl String

  // Master (pre-variant) image facts — base shots only; null for derived crops.
  width         Int?
  height        Int?
  fileSizeBytes Int?

  generationMs Int?
  tokensTotal  Int?

  // Scenic Collection metadata (nullable — null when the Studio backdrop path
  // was used). No FK, same durable-snapshot rationale as the rest of this
  // table. Feeds future data-driven scene recommendations/AI review scoring.
  sceneId        String?
  sceneIntensity String? // "minimal" | "balanced" | "editorial"
  sceneDensity   String? // "minimal" | "classic" | "rich"

  // AI review scores (1–5), null until reviewed
  aiAuthenticity        Float?
  aiRealism             Float?
  aiGarmentPreservation Float?
  aiDrapeQuality        Float?
  aiPatternPreservation Float?
  aiRenderingQuality    Float?
  aiTextureQuality      Float?
  aiProductVisibility   Float?
  aiOverall             Float?
  // JSON array of detected issue strings, e.g. ["soft texture","color shift"].
  aiIssues              String?
  aiReviewModel         String?
  aiReviewedAt          DateTime?

  // Manual review (Phase G), null until rated
  manualScore      Int?
  manualReviewer   String?
  manualReviewedAt DateTime?

  createdAt DateTime @default(now())

  @@index([provider, category])
  @@index([productId])
  @@index([objective])
  @@map("generation_records")
}

// Append-only cost/usage ledger: one row per billable AI API call (NOT per
// generated image — a catalogue run makes 2 paid calls but yields 5 images;
// the 3 close-ups are free Cloudinary crops). Provider/model/feature are plain
// strings so new providers and features need no schema change. `estimatedCostUsd`
// is computed at write time from lib/ai-usage/pricing.ts and stamped with
// `pricingVersion` so historical rows stay reproducible when prices change; the
// raw drivers (tokens, image counts, bytes) are stored alongside so any row can
// be re-priced later. This is the single source of truth for AI cost — quality
// lives separately on GenerationRecord.
model AiUsageEvent {
  id String @id @default(cuid())

  provider  String // "gemini" | "vertex" | future
  model     String // e.g. "gemini-3.1-flash-image", "virtual-try-on-001"
  feature   String // "tryon" | "model_gen" | "catalogue" | "quick_listing" | "metadata_extract" | "voice_search" | "ai_review"
  operation String? // optional sub-type (view, objective, …)

  // Token drivers (Gemini). Null for providers/calls that report no tokens.
  inputTokens  Int?
  outputTokens Int?
  totalTokens  Int?

  // Image drivers. imagesGenerated bills Vertex per-image; imageInputs drives
  // Gemini input tokens (input images are tokenized).
  imagesGenerated Int @default(0)
  imageInputs     Int @default(0)

  // Payload sizes (bytes) — supersede the old JSONL research log.
  requestBytes  Int?
  responseBytes Int?

  durationMs Int?

  // Cost estimate computed at write time; null when the model has no known price.
  estimatedCostUsd Float?
  pricingVersion   String?

  // Attribution. storeId = retailer who owns the product; userId = acting user.
  storeId   String?
  userId    String?
  productId String?

  status       String  @default("success") // "success" | "error"
  errorMessage String?

  // Provider-specific extras (resolution, finishReason, sampleCount, dims …) as
  // a JSON string via lib/serialize.ts. Keeps the table provider-agnostic.
  metadata String?

  createdAt DateTime @default(now())

  @@index([provider, model])
  @@index([feature, createdAt])
  @@index([storeId, createdAt])
  @@index([createdAt])
  @@map("ai_usage_events")
}

// ── AI Casting — Signature Models ────────────────────────────────────────────

// A retailer's Signature Model — a saved *casting brief*, not a stored image.
// Pins one face-library entry (see lib/model-gen/faces.ts) and optionally
// overrides any subset of appearance/style metadata; every unset field is
// smart-picked per product at generation time (lib/model-gen/casting-match.ts).
// This is why no Cloudinary URL lives here: nothing is generated up front, so
// there is nothing to store or clean up.
//
// Delete policy: soft delete only. Historical GenerationRecord rows reference
// this row by id for explainability and audit; the UI hides soft-deleted rows
// and slot counting ignores them. Past catalogue images stay valid forever.
model ModelProfile {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Retailer-facing name (e.g. "Priya — bridal", "Rohan — formal").
  name String

  // Face-library entry id (lib/model-gen/faces.ts). Not a foreign key because
  // the library is code-defined, not a table. Validated at write time.
  faceId String

  // Casting brief — JSON string via lib/model-gen/casting-types.ts. Every
  // field is nullable so retailers explicitly opt into each override; unset
  // fields smart-pick at generation time.
  metadata String

  // "studio" | "editorial" | null. Null defaults to "studio" (catalogue-safe:
  // pose locked by the variant reference). "editorial" drops the variant
  // reference and lets the AI vary pose from occasion + persona.
  poseMode String?

  // Soft delete — never hard-delete or null out. See policy comment above.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, deletedAt])
  @@map("model_profiles")
}

// ── Autonomous AI Catalog Pipeline ──────────────────────────────────────────

// One batch = one "Start" click by the merchant. Tracks aggregate pipeline
// progress across all items in the batch.
model AutoCatalogBatch {
  id     String @id @default(cuid())
  userId String

  status String @default("pending") // pending | running | completed | paused

  // Aggregate counters — updated as items progress through the pipeline
  totalCount      Int @default(0)
  uploadedCount   Int @default(0)
  classifiedCount Int @default(0)
  unknownCount    Int @default(0)
  catalogedCount  Int @default(0)
  imagedCount     Int @default(0)
  qcPassedCount   Int @default(0)
  retryingCount   Int @default(0)
  manualQcCount   Int @default(0)
  publishedCount  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items AutoCatalogItem[]

  @@index([userId])
  @@map("auto_catalog_batches")
}

// One item = one product being processed through the pipeline.
model AutoCatalogItem {
  id      String @id @default(cuid())
  batchId String
  userId  String

  // The uploaded raw image (Cloudinary URL)
  imageUrl String
  mimeType String @default("image/jpeg")
  fileName String @default("")

  // Pipeline stage for this item
  stage String @default("uploaded")
  // uploaded | classifying | unknown | cataloging | generating_images
  // | qc_running | retrying | manual_qc | ready | published | failed

  // Classification output (JSON)
  classificationResult String? // { category, confidence, groupId, allCategories }

  // Catalog output (JSON) — all fields with confidence scores
  catalogResult String?

  // QC output (JSON) — per-check results + overall score
  qcResult String?

  // Retry tracking
  retryCount    Int     @default(0)
  failureReason String?

  // Linked product once published
  productId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch AutoCatalogBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId])
  @@index([userId, stage])
  @@map("auto_catalog_items")
}

// ── AI Fashion Designer ─────────────────────────────────────────────────────

// One design session: fabric + optional assets → AI-generated garment images.
// Separate from the product catalog — lives in the Design Library.
model FashionDesign {
  id          String @id @default(cuid())
  userId      String
  title       String @default("Untitled Design")
  garmentType String @default("")

  // Structured template + customization (Garment Templates / Fabric Flow).
  // templateId references lib/fashion-designer/templates.ts; structuredOptions
  // is a JSON object of the template's field selections (sleeve length, collar
  // style, etc.) — the retailer's structured choices, primary source of truth
  // over AI-inferred designUnderstanding. designNotes is optional free-text
  // refinement (e.g. "white buttons, hidden placket").
  templateId        String?
  structuredOptions String?
  designNotes       String?

  // Pipeline stage
  stage String @default("uploading")
  // uploading | analyzing_fabric | analyzing_design | analyzing_accessories
  // | planning | constructing | generating_flat_images | completed | failed

  // Agent outputs (structured JSON)
  fabricAnalysis      String?
  designUnderstanding String?
  accessoryAnalysis   String?
  generationPlan      String?

  // Generated flat images (Cloudinary URLs)
  flatFrontUrl String?
  flatBackUrl  String?

  qualityScore     Int?
  failureReason    String?
  cancelRequested  Boolean @default(false)
  catalogProductId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets FashionDesignAsset[]

  @@index([userId])
  @@map("fashion_designs")
}

// One uploaded asset per design (fabric, sketch, accessory, etc.)
model FashionDesignAsset {
  id        String @id @default(cuid())
  designId  String
  assetType String // fabric | sketch | reference | accessory | neck | sleeve | back | border | color_palette | other
  url       String
  fileName  String @default("")
  mimeType  String @default("image/jpeg")

  design FashionDesign @relation(fields: [designId], references: [id], onDelete: Cascade)

  @@index([designId])
  @@map("fashion_design_assets")
}

model Recommendation {
  id              String @id @default(cuid())
  sourceProductId String
  targetProductId String

  matchScore    Float
  categoryScore Float
  colorScore    Float
  occasionScore Float
  styleScore    Float
  confidence    Float

  explanation     String
  explanationTags String @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceProduct Product @relation("SourceProduct", fields: [sourceProductId], references: [id], onDelete: Cascade)
  targetProduct Product @relation("TargetProduct", fields: [targetProductId], references: [id], onDelete: Cascade)

  @@unique([sourceProductId, targetProductId])
  @@index([sourceProductId, matchScore])
  @@map("recommendations")
}
