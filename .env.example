# Copy to .env and fill in real values. Do NOT commit .env.

# --- Database (PostgreSQL) ---
# Local dev: a local Postgres instance (see README "Setup").
# Production: the Railway Postgres connection string.
DATABASE_URL="postgresql://pm_dev:pm_dev_pw@localhost:5432/product_match_dev"

# --- Auth ---
JWT_SECRET="your-secret-minimum-32-chars"

# --- MSG91 (customer OTP SMS delivery) ---
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_ROUTE=""
MSG91_DLT_TEMPLATE_ID=""
MSG91_API_URL="http://api.msg91.com/api/sendhttp.php"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Cloudinary (image storage) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# --- AI providers ---
GEMINI_API_KEY=""

# Optional — Vertex AI Virtual Try-On (second provider, off by default)
# See docs/VERTEX_TRYON_SETUP.md
ENABLE_VERTEX_TRYON="false"
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="us-central1"
GOOGLE_APPLICATION_CREDENTIALS=""       # local: path to SA key file
GOOGLE_APPLICATION_CREDENTIALS_JSON=""  # deploy (Railway/Vercel): SA key as base64 JSON

# Optional feature flags / admin
ENABLE_AI_GEN_SETTINGS="false"
ENABLE_BENCHMARK_UPSCALERS="false"
ADMIN_EMAILS=""

# Optional — Replicate (benchmark upscalers)
REPLICATE_API_TOKEN=""
